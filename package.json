{
  "name": "companera",
  "version": "1.0.0",
  "description": "",
  "main": "index",
  "type": "module",
  "scripts": {
    "hardware:setup": "pnpm install && pnpm run hardware:rebuild",
    "hardware:rebuild": "pnpm rebuild && pnpm run hardware:rpi-io",
    "hardware:rpi-io": "npm install --prefix node_modules/rpi-io",
    "start": "tsx src/index.ts",
    "sync:resume": "mutagen sync resume companera",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "fetch-places": "tsx src/scripts/fetch-and-save-places.ts",
    "generate-schema": "openapi-typescript ./src/api/specs/openapi.json -o ./src/api/specs/generated/schema.d.ts"
  },
  "keywords": [],
  "author": "Valentin",
  "license": "ISC",
  "packageManager": "pnpm@10.21.0",
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@types/i2c-bus": "^5.1.2",
    "@types/node": "^25.9.1",
    "@types/oled-i2c-bus": "^1.0.0",
    "eslint": "^10.4.0",
    "oled-i2c-bus": "^1.0.12",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "i2c-bus": "^5.2.3",
    "oled-font-pack": "^1.0.1",
    "rpi-io": "^2.1.1"
  }
}
